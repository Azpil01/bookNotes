<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro de Usuario</title>
        <link rel="stylesheet" href="/styles.css">
</head>
<body class="login-body">
    <div class="login-container">
    <!-- Encabezado de la tarjeta -->
    <div class="login-header">
        <h2>Únete a la biblioteca</h2>
        <p>Crea tu cuenta para empezar a registrar tus lecturas personales</p>
    </div>

    <!-- Alerta de Error: Aparece si el correo ya existe o falla el registro -->
    <% if (locals.error) { %>
        <div class="error-message">
            <%= error %>
        </div>
    <% } %>

    <!-- Formulario que envía los datos a la ruta POST /register -->
    <form action="/register" method="POST" class="login-form">
        
        <!-- Campo de Nombre de Usuario -->
        <div class="form-group">
            <label for="username">Nombre de Usuario</label>
            <input id="font-quick" type="text" id="username" name="username" placeholder="Tu nombre o apodo" required autocomplete="username">
        </div>

        <!-- Campo de Correo Electrónico -->
        <div class="form-group">
            <label for="email">Correo Electrónico</label>
            <input type="email" id="email" name="email" placeholder="ejemplo@correo.com" required autocomplete="email">
        </div>

        <!-- Campo de Contraseña -->
        <div class="form-group">
            <label for="password">Contraseña</label>
            <input type="password" id="password" name="password" placeholder="Mínimo 6 caracteres" required autocomplete="new-password">
        </div>

        <!-- Botón de Registro -->
        <button type="submit" class="btn-login">Registrarse</button>
    </form>

    <!-- Pie de tarjeta para redirigir al Login -->
    <div class="login-footer">
        <p>¿Ya tienes una cuenta? <a href="/">Inicia sesión aquí</a></p>
    </div>
</div>
    
</body>
</html>