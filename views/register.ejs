<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro de Usuario</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="login-body">
    <div class="login-container">
        <!-- Encabezado de la tarjeta -->
        <div class="login-header">
            <h2>Únete a la biblioteca</h2>
            <p>Crea tu cuenta para empezar a registrar tus lecturas personales</p>
        </div>

        <!-- Alerta de Error: Aparece si el correo ya existe o falla el registro -->
        <% if (locals.error) { %>
            <div class="error-message">
                <%= error %>
            </div>
            <% } %>

                <!-- Formulario que envía los datos a la ruta POST /register -->
                <form action="/register" method="POST" class="login-form">

                    <!-- Campo de Nombre de Usuario -->
                    <div class="form-group">
                        <label for="username">Nombre de Usuario</label>
                        <input class="font-quick" type="text" id="username" name="username" placeholder="Tu nombre o apodo"
                            required autocomplete="username">
                        <!-- Contenedor dinámico para mostrar si el usuario está disponible o no -->
                        <small id="username-feedback"
                            style="margin-top: 4px; font-weight: 600; font-size: 12px; display: block; transition: all 0.2s;"></small>
                    </div>

                    <!-- Campo de Correo Electrónico -->
                    <div class="form-group">
                        <label for="email">Correo Electrónico</label>
                        <input type="email" id="email" name="email" placeholder="ejemplo@correo.com" required
                            autocomplete="email">
                    </div>

                    <!-- Campo de Contraseña -->
                    <div class="form-group">
                        <label for="password">Contraseña</label>
                        <input type="password" id="password" name="password" placeholder="Mínimo 6 caracteres" required
                            autocomplete="new-password">
                    </div>

                    <!-- Botón de Registro -->
                    <button type="submit" class="btn-login">Registrarse</button>
                </form>

                <!-- Pie de tarjeta para redirigir al Login -->
                <div class="login-footer">
                    <p>¿Ya tienes una cuenta? <a href="/">Inicia sesión aquí</a></p>
                </div>
    </div>

    <script>
        const usernameInput = document.getElementById("username"); //Podemos manipular ele elemento con este id
        const feedback = document.getElementById("username-feedback");
        const submitBtn = document.querySelector(".btn-login"); //Podemos manipular el elemento con esta clase

        let typingTimer; //Variable para controlar el retraso al escribir y no saturar al servidor con peticiones por cada letra

        usernameInput.addEventListener("input", () => {
            clearTimeout(typingTimer); //Se limpia el temporizador anterior

            const username = usernameInput.value.trim(); //Toma el valor que este en usernameInput y le quita los espacios

            if (username.length < 3) {
                feedback.textContent = username.length > 0 ? "El usuario debe tener mínimo 3 caracteres." : "";
                feedback.style.color = "#718096"
                submitBtn.disabled = false;
                submitBtn.style.opacity = 1;
                return;
            }
            typingTimer = setTimeout(async () => {
                feedback.textContent = "Verificando disponibilidad";
                feedback.style.color = "#3182ce";

                try {
                    const response = await fetch(`/api/check-username?username=${encodeURIComponent(username)}`);
                    const data = await response.json()

                    if (data.available) {
                        feedback.textContent = `El usuario: "${username}" se encuentra disponible`;
                        feedback.style.color = "#2f855a"; // Color verde éxito
                        submitBtn.disabled = false;
                        submitBtn.style.opacity = "1";
                    } else {
                        feedback.textContent = `El nombre de usuario "${username}" ya está ocupado.`;
                        feedback.style.color = "#c53030"; // Color rojo error
                        submitBtn.disabled = true; // Bloqueamos el botón de registro
                        submitBtn.style.opacity = "0.5"; // Lo hacemos ver deshabilitado
                    }
                } catch (err) {
                    console.error("Error al consultar disponibilidad del usuario:", err);
                    feedback.textContent = "No se pudo verificar la disponibilidad en este momento.";
                    feedback.style.color = "#dd6b20"; // Color naranja de advertencia
                }


            }, 400);
        });

    </script>

</body>

</html>