<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+Display:ital,wght@0,100..900;1,100..900&family=Quicksand:wght@300..700&display=swap"
        rel="stylesheet">
    <title>Notas Bibliográficas</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <header class="title-header">
        <section class="titulo">
            <h2>Notas Bibliográficas</h2>
            <a href="/addbook"> + Agregar nuevo libro</a>
        </section>
    </header>

    <main class="grid-container">
        <% books.forEach(book=> { %>
            <article class="libro-card">
                <section class="portada-wrapper">
                    <a href="/book/<%= book.id %>">
                        <img src="<%= book.cover_url %>" alt="portada de <%= book.title  %>">
                    </a>
                </section>

                <section class="card-content">
                    <header class="info">
                        <h2>
                            <%= book.title %>
                        </h2>
                        <h3>
                            <%= book.author %>
                        </h3>
                    </header>


                    <div class="puntuacion">
                        <p>
                            <%= "⭐" .repeat(book.score) %>
                                <%= "☆" .repeat(5-book.score) %>
                        </p>
                    </div>

                    <section class="resument-corto">
                        <p>
                            <%= book.user_resume ? book.user_resume.substring(0, 150) + "...": "Sin resumen disponible." %> 
                        </p>
                    </section>
                    <a href="/book/<%= book.id %>" class="btn-leer-mas">Leer notas completas</a>
                </section>
            </article>


            <% }); %>

    </main>
    <footer>

    </footer>

</body>

</html>